package rotateObject

import de.fabmax.kool.KoolApplication
import de.fabmax.kool.math.deg
import de.fabmax.kool.math.Vec3f
import de.fabmax.kool.modules.ksl.KslPbrShader
import de.fabmax.kool.scene.*
import de.fabmax.kool.modules.ui2.*
import de.fabmax.kool.pipeline.ClearColorDepthLoad
import de.fabmax.kool.util.Color
import de.fabmax.kool.util.MdColor
import de.fabmax.kool.scene.geometry.*

fun main() = KoolApplication {
    
    lateinit var cubeNode: Node
    
    // Сцена 1: 3D контент
    addScene {
        defaultOrbitCamera()

        cubeNode = addColorMesh {
            generate {
                cube { colored() }
            }
            shader = KslPbrShader {
                color { vertexColor() }
                metallic(0.1f)
                roughness(0.3f)
            }
        }

        lighting.singleDirectionalLight {
            setup(Vec3f(-1f, -1f, -1f))
            setColor(Color.WHITE, 5f)
        }
        
        // Очищаем цвет И глубину для 3D
        mainRenderPass.clearColors = ClearColorDepthLoad
    }

    // Сцена 2: UI (поверх 3D)
    addScene {
        // Очищаем ТОЛЬКО глубину, сохраняя цвет от 3D сцены
        mainRenderPass.clearDepth = true
        mainRenderPass.clearColors = null // НЕ очищаем цвет!
        
        UiScene(this).apply {
            addPanelSurface(
                colors = Colors.singleColorLight(MdColor.BLUE_GREY)
            ) {
                modifier
                    .size(300.dp, 200.dp)
                    .align(AlignmentX.End, AlignmentY.Top)
                    .margin(16.dp)
                    .background(RoundRectBackground(colors.background, 12.dp))

                Column {
                    modifier
                        .alignX(AlignmentX.Center)
                        .margin(16.dp)

                    Text("Управление вращением") {
                        modifier
                            .margin(bottom = 16.dp)
                            .textColor(Color.WHITE)
                    }

                    Button("Влево") {
                        modifier
                            .padding(horizontal = 12.dp, vertical = 8.dp)
                            .onClick {
                                cubeNode.transform.rotate((-10f).deg, Vec3f.Y_AXIS)
                            }
                    }
                    
                    Button("Вправо") {
                        modifier
                            .padding(horizontal = 12.dp, vertical = 8.dp)
                            .onClick {
                                cubeNode.transform.rotate(10f.deg, Vec3f.Y_AXIS)
                            }
                    }
                    
                    Button("Сброс") {
                        modifier
                            .padding(horizontal = 12.dp, vertical = 8.dp)
                            .onClick {
                                cubeNode.transform.setIdentity()
                            }
                    }
                }
            }
        }
    }
}
